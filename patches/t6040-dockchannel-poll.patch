 #include <linux/platform_device.h>
 #include <linux/spinlock.h>
 #include <linux/unaligned.h>
+#include <linux/workqueue.h>
 
 #define APPLE_DOCKCHANNEL_FIFO_SIZE	0x800
 
+/*
+ * Polled-mode period. On t6040 the ADT-declared AIC line for the
+ * dockchannel-uart FIFO never asserts (all 4096 AIC inputs were scanned with
+ * the FIFO irq flags latched and unmasked); both m1n1 and the KIS dock-side
+ * agent poll this FIFO. 5 ms against a 2 KiB FIFO is far more bandwidth than
+ * a debug console needs.
+ */
+#define APPLE_DOCKCHANNEL_POLL_MS	5
+
 #define IRQ_MASK			0x0
 #define IRQ_FLAG			0x4
 
