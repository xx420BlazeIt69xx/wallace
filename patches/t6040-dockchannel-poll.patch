-					apple_dockchannel_irq_thread, IRQF_ONESHOT,
-					dev_name(dev), dc);
-	if (ret)
-		return dev_err_probe(dev, ret, "failed to request IRQ\n");
+	dc->poll_mode = of_property_read_bool(dev->of_node, "apple,poll-mode");
+	INIT_DELAYED_WORK(&dc->poll_work, apple_dockchannel_poll_work);
 
-	disable_irq(dc->irq);
+	if (dc->poll_mode) {
